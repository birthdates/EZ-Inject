{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EZInject",
  "version": "0.1.0",
  "identifier": "com.ezinject.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EZInject",
        "width": 1320,
        "height": 840,
        "minWidth": 1320,
        "minHeight": 840,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
